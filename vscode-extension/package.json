{
  "name": "vscode-codex-session-manager",
  "displayName": "Codex 会话管理 / Codex Session Manager",
  "description": "按项目管理 VS Code Codex 会话，并可跳转官方 Codex 继续对话。 Project-aware Codex sessions for VS Code with official Codex handoff.",
  "version": "0.1.27",
  "publisher": "wangzhilin777",
  "license": "MIT",
  "icon": "resources/codex-sessions.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/wangzhilin777/vscode-codex-session-manager.git"
  },
  "homepage": "https://github.com/wangzhilin777/vscode-codex-session-manager",
  "bugs": {
    "url": "https://github.com/wangzhilin777/vscode-codex-session-manager/issues"
  },
  "keywords": [
    "codex",
    "openai",
    "sessions",
    "workspace",
    "chat"
  ],
  "engines": {
    "vscode": "^1.95.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onView:codexSessions.inlineSearch",
    "onView:codexSessions.tree",
    "onCommand:codexSessions.refresh",
    "onCommand:codexSessions.openDetails",
    "onCommand:codexSessions.openInOfficialCodex",
    "onCommand:codexSessions.toggleCurrentProjectOnly",
    "onCommand:codexSessions.showCurrentWorkspace",
    "onCommand:codexSessions.showAllWorkspaces",
    "onCommand:codexSessions.toggleArchived",
    "onCommand:codexSessions.setSearchFilter",
    "onCommand:codexSessions.clearSearchFilter",
    "onCommand:codexSessions.searchAndOpenSession",
    "onCommand:codexSessions.setAlias",
    "onCommand:codexSessions.setProjectTag",
    "onCommand:codexSessions.setNote",
    "onCommand:codexSessions.resumeInTerminal",
    "onCommand:codexSessions.archiveSession",
    "onCommand:codexSessions.unarchiveSession",
    "onCommand:codexSessions.deleteSession",
    "onCommand:codexSessions.togglePinSession",
    "onCommand:codexSessions.toggleUnreadSession",
    "onCommand:codexSessions.copySessionId",
    "onCommand:codexSessions.copyWorkingDirectory",
    "onCommand:codexSessions.copyDeepLink",
    "onCommand:codexSessions.copyResumeCommand",
    "onCommand:codexSessions.openSessionWorkspace",
    "onCommand:codexSessions.revealSessionWorkspace",
    "onCommand:codexSessions.revealSessionFile",
    "onCommand:codexSessions.openSessionWorkspaceNewWindow",
    "onCommand:codexSessions.forkInTerminal"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "codexSessions",
          "title": "%viewsContainer.codexSessions.title%",
          "icon": "resources/codex-sessions.svg"
        }
      ]
    },
    "views": {
      "codexSessions": [
        {
          "id": "codexSessions.inlineSearch",
          "name": "%view.codexSessions.inlineSearch.name%",
          "type": "webview"
        },
        {
          "id": "codexSessions.tree",
          "name": "%view.codexSessions.tree.name%"
        }
      ]
    },
    "commands": [
      {
        "command": "codexSessions.refresh",
        "title": "%command.refresh.title%",
        "icon": "$(refresh)"
      },
      {
        "command": "codexSessions.toggleCurrentProjectOnly",
        "title": "%command.toggleCurrentProjectOnly.title%",
        "icon": "$(filter)"
      },
      {
        "command": "codexSessions.showCurrentWorkspace",
        "title": "%command.showCurrentWorkspace.title%",
        "icon": "$(root-folder)"
      },
      {
        "command": "codexSessions.showAllWorkspaces",
        "title": "%command.showAllWorkspaces.title%",
        "icon": "$(globe)"
      },
      {
        "command": "codexSessions.toggleArchived",
        "title": "%command.toggleArchived.title%",
        "icon": "$(archive)"
      },
      {
        "command": "codexSessions.setSearchFilter",
        "title": "%command.setSearchFilter.title%",
        "icon": "$(search)"
      },
      {
        "command": "codexSessions.clearSearchFilter",
        "title": "%command.clearSearchFilter.title%",
        "icon": "$(close)"
      },
      {
        "command": "codexSessions.searchAndOpenSession",
        "title": "%command.searchAndOpenSession.title%",
        "icon": "$(search)"
      },
      {
        "command": "codexSessions.openDetails",
        "title": "%command.openDetails.title%",
        "icon": "$(book)"
      },
      {
        "command": "codexSessions.openInOfficialCodex",
        "title": "%command.openInOfficialCodex.title%",
        "icon": "$(rocket)"
      },
      {
        "command": "codexSessions.setAlias",
        "title": "%command.setAlias.title%",
        "icon": "$(edit)"
      },
      {
        "command": "codexSessions.setProjectTag",
        "title": "%command.setProjectTag.title%"
      },
      {
        "command": "codexSessions.setNote",
        "title": "%command.setNote.title%"
      },
      {
        "command": "codexSessions.resumeInTerminal",
        "title": "%command.resumeInTerminal.title%",
        "icon": "$(terminal)"
      },
      {
        "command": "codexSessions.forkInTerminal",
        "title": "%command.forkInTerminal.title%",
        "icon": "$(git-branch)"
      },
      {
        "command": "codexSessions.togglePinSession",
        "title": "%command.togglePinSession.title%",
        "icon": "$(pinned)"
      },
      {
        "command": "codexSessions.toggleUnreadSession",
        "title": "%command.toggleUnreadSession.title%",
        "icon": "$(circle-large-filled)"
      },
      {
        "command": "codexSessions.archiveSession",
        "title": "%command.archiveSession.title%",
        "icon": "$(archive)"
      },
      {
        "command": "codexSessions.unarchiveSession",
        "title": "%command.unarchiveSession.title%",
        "icon": "$(reply)"
      },
      {
        "command": "codexSessions.deleteSession",
        "title": "%command.deleteSession.title%",
        "icon": "$(trash)"
      },
      {
        "command": "codexSessions.copySessionId",
        "title": "%command.copySessionId.title%"
      },
      {
        "command": "codexSessions.copyWorkingDirectory",
        "title": "%command.copyWorkingDirectory.title%",
        "icon": "$(folder)"
      },
      {
        "command": "codexSessions.copyDeepLink",
        "title": "%command.copyDeepLink.title%",
        "icon": "$(link)"
      },
      {
        "command": "codexSessions.copyResumeCommand",
        "title": "%command.copyResumeCommand.title%"
      },
      {
        "command": "codexSessions.openSessionWorkspace",
        "title": "%command.openSessionWorkspace.title%"
      },
      {
        "command": "codexSessions.openSessionWorkspaceNewWindow",
        "title": "%command.openSessionWorkspaceNewWindow.title%",
        "icon": "$(empty-window)"
      },
      {
        "command": "codexSessions.revealSessionWorkspace",
        "title": "%command.revealSessionWorkspace.title%",
        "icon": "$(folder-opened)"
      },
      {
        "command": "codexSessions.revealSessionFile",
        "title": "%command.revealSessionFile.title%"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "codexSessions.refresh",
          "when": "view == codexSessions.tree",
          "group": "navigation@1"
        },
        {
          "command": "codexSessions.showCurrentWorkspace",
          "when": "view == codexSessions.tree && !codexSessions.currentProjectOnly",
          "group": "navigation@2"
        },
        {
          "command": "codexSessions.showAllWorkspaces",
          "when": "view == codexSessions.tree && codexSessions.currentProjectOnly",
          "group": "navigation@2"
        },
        {
          "command": "codexSessions.toggleCurrentProjectOnly",
          "when": "view == codexSessions.tree",
          "group": "navigation@2.5"
        },
        {
          "command": "codexSessions.toggleArchived",
          "when": "view == codexSessions.tree",
          "group": "navigation@3"
        },
        {
          "command": "codexSessions.searchAndOpenSession",
          "when": "view == codexSessions.tree",
          "group": "navigation@4"
        }
      ],
      "view/item/context": [
        {
          "command": "codexSessions.openInOfficialCodex",
          "when": "view == codexSessions.tree && viewItem == session",
          "group": "inline@1"
        },
        {
          "command": "codexSessions.openDetails",
          "when": "view == codexSessions.tree && viewItem == session",
          "group": "open@1"
        },
        {
          "command": "codexSessions.resumeInTerminal",
          "when": "view == codexSessions.tree && viewItem == session",
          "group": "inline@2"
        },
        {
          "command": "codexSessions.setAlias",
          "when": "view == codexSessions.tree && viewItem == session",
          "group": "manage@2"
        },
        {
          "command": "codexSessions.setProjectTag",
          "when": "view == codexSessions.tree && viewItem == session",
          "group": "edit@1"
        },
        {
          "command": "codexSessions.setNote",
          "when": "view == codexSessions.tree && viewItem == session",
          "group": "edit@2"
        },
        {
          "command": "codexSessions.togglePinSession",
          "when": "view == codexSessions.tree && viewItem == session",
          "group": "manage@1"
        },
        {
          "command": "codexSessions.archiveSession",
          "when": "view == codexSessions.tree && viewItem == session",
          "group": "manage@3"
        },
        {
          "command": "codexSessions.toggleUnreadSession",
          "when": "view == codexSessions.tree && viewItem == session",
          "group": "manage@4"
        },
        {
          "command": "codexSessions.unarchiveSession",
          "when": "view == codexSessions.tree && viewItem == sessionArchived",
          "group": "manage@1"
        },
        {
          "command": "codexSessions.deleteSession",
          "when": "view == codexSessions.tree && viewItem == sessionArchived",
          "group": "manage@2"
        },
        {
          "command": "codexSessions.copySessionId",
          "when": "view == codexSessions.tree && viewItem == session",
          "group": "copy@2"
        },
        {
          "command": "codexSessions.copyWorkingDirectory",
          "when": "view == codexSessions.tree && viewItem == session",
          "group": "copy@1"
        },
        {
          "command": "codexSessions.copyDeepLink",
          "when": "view == codexSessions.tree && viewItem == session",
          "group": "copy@3"
        },
        {
          "command": "codexSessions.copyResumeCommand",
          "when": "view == codexSessions.tree && viewItem == session",
          "group": "copy@4"
        },
        {
          "command": "codexSessions.revealSessionWorkspace",
          "when": "view == codexSessions.tree && viewItem == session",
          "group": "open@2"
        },
        {
          "command": "codexSessions.openSessionWorkspace",
          "when": "view == codexSessions.tree && viewItem == session",
          "group": "open@3"
        },
        {
          "command": "codexSessions.openSessionWorkspaceNewWindow",
          "when": "view == codexSessions.tree && viewItem == session",
          "group": "open@4"
        },
        {
          "command": "codexSessions.revealSessionFile",
          "when": "view == codexSessions.tree && viewItem == session",
          "group": "open@5"
        },
        {
          "command": "codexSessions.forkInTerminal",
          "when": "view == codexSessions.tree && viewItem == session",
          "group": "fork@1"
        },
        {
          "command": "codexSessions.openInOfficialCodex",
          "when": "view == codexSessions.tree && viewItem == sessionArchived",
          "group": "inline@1"
        },
        {
          "command": "codexSessions.openDetails",
          "when": "view == codexSessions.tree && viewItem == sessionArchived",
          "group": "open@1"
        },
        {
          "command": "codexSessions.copySessionId",
          "when": "view == codexSessions.tree && viewItem == sessionArchived",
          "group": "copy@2"
        },
        {
          "command": "codexSessions.copyWorkingDirectory",
          "when": "view == codexSessions.tree && viewItem == sessionArchived",
          "group": "copy@1"
        },
        {
          "command": "codexSessions.copyDeepLink",
          "when": "view == codexSessions.tree && viewItem == sessionArchived",
          "group": "copy@3"
        },
        {
          "command": "codexSessions.copyResumeCommand",
          "when": "view == codexSessions.tree && viewItem == sessionArchived",
          "group": "copy@4"
        },
        {
          "command": "codexSessions.revealSessionWorkspace",
          "when": "view == codexSessions.tree && viewItem == sessionArchived",
          "group": "open@2"
        },
        {
          "command": "codexSessions.openSessionWorkspace",
          "when": "view == codexSessions.tree && viewItem == sessionArchived",
          "group": "open@3"
        },
        {
          "command": "codexSessions.openSessionWorkspaceNewWindow",
          "when": "view == codexSessions.tree && viewItem == sessionArchived",
          "group": "open@4"
        },
        {
          "command": "codexSessions.revealSessionFile",
          "when": "view == codexSessions.tree && viewItem == sessionArchived",
          "group": "open@5"
        }
      ]
    },
    "configuration": {
      "title": "%configuration.title%",
      "properties": {
        "codexSessionManager.dataSourceMode": {
          "type": "string",
          "enum": [
            "auto",
            "appServerOnly",
            "filesystemOnly"
          ],
          "default": "auto",
          "description": "%configuration.dataSourceMode.description%"
        },
        "codexSessionManager.currentProjectOnlyDefault": {
          "type": "boolean",
          "default": false,
          "description": "%configuration.currentProjectOnlyDefault.description%"
        },
        "codexSessionManager.showArchivedDefault": {
          "type": "boolean",
          "default": true,
          "description": "%configuration.showArchivedDefault.description%"
        },
        "codexSessionManager.includeExecSessions": {
          "type": "boolean",
          "default": true,
          "description": "%configuration.includeExecSessions.description%"
        },
        "codexSessionManager.includeSubagentSessions": {
          "type": "boolean",
          "default": false,
          "description": "%configuration.includeSubagentSessions.description%"
        },
        "codexSessionManager.refreshIntervalSeconds": {
          "type": "number",
          "default": 20,
          "minimum": 5,
          "maximum": 600,
          "description": "%configuration.refreshIntervalSeconds.description%"
        },
        "codexSessionManager.detailTurnFetchMode": {
          "type": "string",
          "enum": [
            "summary",
            "full"
          ],
          "default": "summary",
          "description": "%configuration.detailTurnFetchMode.description%"
        },
        "codexSessionManager.codexHomeOverride": {
          "type": "string",
          "default": "",
          "description": "%configuration.codexHomeOverride.description%"
        },
        "codexSessionManager.codexCliPath": {
          "type": "string",
          "default": "codex",
          "description": "%configuration.codexCliPath.description%"
        },
        "codexSessionManager.focusCurrentWorkspaceOnViewOpen": {
          "type": "boolean",
          "default": false,
          "description": "%configuration.focusCurrentWorkspaceOnViewOpen.description%"
        },
        "codexSessionManager.enableDiskCache": {
          "type": "boolean",
          "default": true,
          "description": "%configuration.enableDiskCache.description%"
        }
      }
    }
  },
  "scripts": {
    "build": "tsc -p .",
    "watch": "tsc -w -p .",
    "test": "npm run build && node --test out/test/**/*.test.js",
    "package:vsix": "npm run build && node ./scripts/package-vsix.mjs"
  },
  "devDependencies": {
    "@types/node": "^24.0.10",
    "@types/vscode": "^1.95.0",
    "@vscode/vsce": "^3.6.0",
    "typescript": "^5.8.3"
  }
}
